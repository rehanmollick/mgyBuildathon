# Anthropic Claude API key (for Strategy Architect, Analyst, Mutator agents)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Model selection (defaults to claude-opus-4-6 if unset)
QUANTFORGE_CLAUDE_MODEL=claude-opus-4-6

# Market Imaginer generator: "gbm" (default) or "kronos"
QUANTFORGE_GENERATOR=gbm

# Backend host/port for local dev
QUANTFORGE_HOST=127.0.0.1
QUANTFORGE_PORT=8000

# CORS allowed origins, comma separated
QUANTFORGE_CORS_ORIGINS=http://localhost:3000

# Log level (DEBUG, INFO, WARNING, ERROR)
QUANTFORGE_LOG_LEVEL=INFO

# Default scenario count for /api/forge
QUANTFORGE_N_SCENARIOS=200

# Safe exec timeout for user strategy code (seconds)
QUANTFORGE_EXEC_TIMEOUT=5.0
